declare S64_CORE_PATH_ROOT="${S64_CORE_PATH_ROOT:-/opt/sysop64}"
[[ ! -d "$S64_CORE_PATH_ROOT" ]] && S64_CORE_PATH_ROOT="${HOME}/at64/sysop64"
# shellcheck source=../lib/core.lib
source "${S64_CORE_PATH_ROOT}/lib/core.lib" || { s64_core_lib_module_check && exit 1; }
# shellcheck disable=SC2015
source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-core.bash" || { s64_core_lib_check_bl64 && exit 1; }

declare MY_COMMAND=''
declare MY_OPTION=''

declare MY_COMMAND_HELP='help'
declare MY_COMMAND_INFO='info'
declare MY_COMMAND_LS_MOD='mods'
declare MY_COMMAND_LS_TASK='tasks'
declare MY_COMMAND_RUN='run'
declare MY_COMMAND_SHOW='show'

function my_check_module() {
  bl64_dbg_app_show_function "$@"
  local module="${1:-}"

  bl64_check_parameter 'module' ||
    return $?

  [[ -d "${S64_CORE_PATH_MOD}/${module}" ]] &&
    return 0

  bl64_msg_show_fatal "Module not found. Please check and try again (module=${module})"
  return "$BL64_LIB_ERROR_PARAMETER_INVALID"
}

function my_check_task() {
  bl64_dbg_app_show_function "$@"
  local module="${1:-}"
  local task="${2:-}"

  my_check_module "$module" &&
    bl64_check_parameter 'task' ||
    return $?

  [[ -e "${S64_CORE_PATH_MOD}/${module}/${module}-${task}" ]] &&
    return 0

  bl64_msg_show_fatal "Task not found. Please check and try again (task=${module}/${task})"
  return "$BL64_LIB_ERROR_PARAMETER_INVALID"
}

function my_show() {
  bl64_dbg_app_show_function "$@"
  local module="${1:-}"
  local task="${2:-}"
  shift 2
  my_check_task "$module" "$task" &&
    bl64_txt_strip_comments "${S64_CORE_PATH_MOD}/${module}/${module}-${task}"
}

function my_run() {
  bl64_dbg_app_show_function "$@"
  local module="${1:-}"
  local task="${2:-}"
  shift 2
  my_check_task "$module" "$task" &&
    "${S64_CORE_PATH_MOD}/${module}/${module}-${task}" "$@"
}

function my_mods() {
  bl64_dbg_app_show_function "$@"
  cd "$S64_CORE_PATH_MOD" &&
    bl64_fs_run_ls -1 |
    bl64_txt_run_sort
}

function my_tasks() {
  bl64_dbg_app_show_function "$@"
  local module="${1:-}"
  my_check_module "$module" &&
    cd "$S64_CORE_PATH_MOD/$module" &&
    bl64_fs_run_ls -1 |
    bl64_txt_run_sed "s/${module}-//g"
}

function my_info() {
  bl64_dbg_app_show_function "$@"
  local module="${1:-}"
  local task="${2:-}"
  shift 2
  my_check_task "$module" "$task" &&
    S64_CORE_SET_TASK="$S64_CORE_TASK_MODE_HELP" "${S64_CORE_PATH_MOD}/${module}/${module}-${task}"
}

function my_initialize() {
  bl64_dbg_app_show_function
  [[ -z "$MY_OPTION" || -z "$MY_COMMAND" ]] &&
    BL64_MSG_FORMAT="$BL64_MSG_FORMAT_PLAIN" bl64_msg_show_error 'missing command name' &&
    bl64_msg_help_show &&
    return 1

  bl64_lib_script_minver_check "$S64_BL64_VERSION" ||
    return $?
  case "$MY_COMMAND" in
    'i' | "$MY_COMMAND_INFO") MY_COMMAND="$MY_COMMAND_INFO" ;;
    'm' | "$MY_COMMAND_LS_MOD") MY_COMMAND="$MY_COMMAND_LS_MOD" ;;
    't' | "$MY_COMMAND_LS_TASK") MY_COMMAND="$MY_COMMAND_LS_TASK" ;;
    'r' | "$MY_COMMAND_RUN") MY_COMMAND="$MY_COMMAND_RUN" ;;
    's' | "$MY_COMMAND_SHOW") MY_COMMAND="$MY_COMMAND_SHOW" ;;
    *) bl64_msg_show_error "invalid command name (${MY_COMMAND})" && return 1 ;;
  esac
}

bl64_lib_script_version_set '2.0.1'
bl64_msg_help_usage_set '[-V format] [-D Debug] <COMMAND> [MODULE] [TASK] [PARAMETERS]'
bl64_msg_help_about_set 'Run sysadmin tasks'
bl64_msg_help_parameters_set \
  "Commands:

i|${MY_COMMAND_INFO}     : Show task about.
m|${MY_COMMAND_LS_MOD}     : List modules.
t|${MY_COMMAND_LS_TASK}    : List tasks.
r|${MY_COMMAND_RUN}      : Run a module/task.
s|${MY_COMMAND_SHOW}     : Show task script content.
h|${MY_COMMAND_HELP}     : Show this help message.

Show & Run options:

MODULE     : Module name. Required for show and run.
TASK       : Module task name. Required for show and run.
PARAMETERS : (Optional). Task parameters

Global Options:

-V FORMAT  : verbose message format. Format: BL64_MSG_FORMAT_*
-D DEBUG   : Enable debugging mode. Format: BL64_DBG_TARGET_*"

# shellcheck disable=SC2249,SC2034
while getopts ':V:D:' MY_OPTION; do
  case "${MY_OPTION:-}" in
    V) bl64_msg_set_level "$OPTARG" && S64_CORE_SET_VERBOSE="$OPTARG" ;;
    D) bl64_dbg_set_level "$OPTARG" && S64_CORE_SET_DEBUG="$OPTARG" ;;
    *) bl64_msg_show_error "invalid option ($OPTARG)" && exit 1 ;;
  esac
done

shift $((OPTIND - 1))
MY_COMMAND="${1:-}"
[[ "$MY_COMMAND" =~ ($MY_COMMAND_HELP|h) ]] && bl64_msg_help_show && exit 0
shift
my_initialize || exit $?

"my_${MY_COMMAND}" "${@:-}"
