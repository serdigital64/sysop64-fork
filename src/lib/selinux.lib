#
# Imports
#

# shellcheck disable=SC2154,SC2015
source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" ||
  { s64_core_lib_check_bl64 && exit 1; }

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_SELINUX_VERSION='1.0.0'
  declare S64_SELINUX_ABOUT_MODULE_MAIN='SELinux - Mandatory Access Control System'

  declare S64_SELINUX_PATH_CLI_SESTATUS='/usr/sbin/sestatus'
}

#
# Functions
#

function s64_selinux_lib_setup() {
  bl64_dbg_app_show_function
  s64_core_lib_module_show_about "$S64_SELINUX_ABOUT_MODULE_MAIN" &&
    bl64_os_check_flavor \
      "$BL64_OS_FLAVOR_SUSE" \
      "$BL64_OS_FLAVOR_FEDORA" \
      "$BL64_OS_FLAVOR_REDHAT" &&
    bl64_check_command "$S64_SELINUX_PATH_CLI_SESTATUS"
}

function s64_selinux_lib_run_sestatus() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  "$S64_SELINUX_PATH_CLI_SESTATUS" \
    "$@"
  bl64_dbg_app_trace_stop
}
