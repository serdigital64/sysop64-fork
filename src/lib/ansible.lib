#
# Imports
#

# shellcheck disable=SC2154,SC2015
source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" ||
  { s64_core_lib_check_bl64 && exit 1; }

#
# Module parameters
#

# shellcheck disable=SC2034
{
  declare S64_ANSIBLE_PATH_CLI_ANSIBLE="${S64_ANSIBLE_PATH_CLI_ANSIBLE:-}"
  declare S64_ANSIBLE_PATH_CLI_CONFIG="${S64_ANSIBLE_PATH_CLI_CONFIG:-}"
  declare S64_ANSIBLE_PATH_CLI_DOC="${S64_ANSIBLE_PATH_CLI_DOC:-}"
  declare S64_ANSIBLE_PATH_CLI_GALAXY="${S64_ANSIBLE_PATH_CLI_GALAXY:-}"
  declare S64_ANSIBLE_PATH_CLI_INVENTORY="${S64_ANSIBLE_PATH_CLI_INVENTORY:-}"
  declare S64_ANSIBLE_PATH_CLI_PLAYBOOK="${S64_ANSIBLE_PATH_CLI_PLAYBOOK:-}"

  declare S64_ANSIBLE_PATH_INVENTORY="${S64_ANSIBLE_PATH_INVENTORY:-}"
  declare S64_ANSIBLE_PATH_CONFIG="${S64_ANSIBLE_PATH_CONFIG:-}"

  declare S64_ANSIBLE_SET_OUTPUT_PLUGIN="${S64_ANSIBLE_SET_OUTPUT_PLUGIN:-default}"
}

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_ANSIBLE_VERSION='1.2.1'
  declare S64_ANSIBLE_ABOUT_MODULE_MAIN='Ansible Platform'

  declare S64_ANSIBLE_SET_VERBOSE='--verbose'
  declare S64_ANSIBLE_SET_DEBUG='-vvvvv'
}

#
# External
#

# shellcheck disable=SC2034
{
  export ANSIBLE_STDOUT_CALLBACK
  export ANSIBLE_INVENTORY
  export ANSIBLE_CONFIG
}

#
# Functions
#

function s64_ansible_lib_setup() {
  bl64_dbg_app_show_function

  bl64_msg_app_detail_is_enabled || S64_ANSIBLE_SET_VERBOSE=' '
  bl64_dbg_app_command_is_enabled || S64_ANSIBLE_SET_DEBUG=' '

  s64_core_lib_module_show_about "$S64_ANSIBLE_ABOUT_MODULE_MAIN" &&
    s64_core_lib_command_require 'S64_ANSIBLE_PATH_CLI_ANSIBLE' 'ansible' &&
    s64_core_lib_command_require 'S64_ANSIBLE_PATH_CLI_CONFIG' 'ansible-config' &&
    s64_core_lib_command_require 'S64_ANSIBLE_PATH_CLI_DOC' 'ansible-doc' &&
    s64_core_lib_command_require 'S64_ANSIBLE_PATH_CLI_GALAXY' 'ansible-galaxy' &&
    s64_core_lib_command_require 'S64_ANSIBLE_PATH_CLI_INVENTORY' 'ansible-inventory' &&
    s64_core_lib_command_require 'S64_ANSIBLE_PATH_CLI_PLAYBOOK' 'ansible-playbook' &&
    s64_core_lib_module_show_setup \
      'S64_ANSIBLE_PATH_INVENTORY' \
      'S64_ANSIBLE_PATH_CONFIG'
}

function s64_ansible_lib_cli_set() {
  bl64_dbg_app_show_function

  ANSIBLE_STDOUT_CALLBACK="$S64_ANSIBLE_SET_OUTPUT_PLUGIN"

  if [[ -f "$S64_ANSIBLE_PATH_INVENTORY" ]]; then
    ANSIBLE_INVENTORY="$S64_ANSIBLE_PATH_INVENTORY"
  else
    ANSIBLE_INVENTORY='/dev/null'
  fi

  if [[ -f "$S64_ANSIBLE_PATH_CONFIG" ]]; then
    ANSIBLE_CONFIG="$S64_ANSIBLE_PATH_CONFIG"
  else
    unset ANSIBLE_CONFIG
  fi

  return 0
}

function _s64_ansible_lib_cli_harden() {
  bl64_dbg_app_show_function

  bl64_dbg_lib_trace_start
  unset ANSIBLE_CACHE_PLUGIN_CONNECTION
  unset ANSIBLE_COLLECTIONS_PATHS
  unset ANSIBLE_GALAXY_CACHE_DIR
  unset ANSIBLE_GALAXY_TOKEN_PATH
  unset ANSIBLE_LOCAL_TEMP
  unset ANSIBLE_LOG_PATH
  unset ANSIBLE_PERSISTENT_CONTROL_PATH_DIR
  unset ANSIBLE_PLAYBOOK_DIR
  unset ANSIBLE_PRIVATE_KEY_FILE
  unset ANSIBLE_ROLES_PATH
  unset ANSIBLE_SSH_CONTROL_PATH_DIR
  unset ANSIBLE_VAULT_PASSWORD_FILE
  unset ANSIBLE_RETRY_FILES_SAVE_PATH
  bl64_dbg_lib_trace_stop
}

function s64_ansible_lib_run_playbook() {
  bl64_dbg_app_show_function "$@"
  _s64_ansible_lib_cli_harden
  s64_ansible_lib_cli_set

  bl64_dbg_app_trace_start
  # shellcheck disable=SC2086
  "$S64_ANSIBLE_PATH_CLI_PLAYBOOK" \
    $S64_ANSIBLE_SET_VERBOSE $S64_ANSIBLE_SET_DEBUG \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_ansible_lib_run_ansible() {
  bl64_dbg_app_show_function "$@"

  _s64_ansible_lib_cli_harden
  s64_ansible_lib_cli_set

  bl64_dbg_app_trace_start
  # shellcheck disable=SC2086
  "$S64_ANSIBLE_PATH_CLI_ANSIBLE" \
    $S64_ANSIBLE_SET_VERBOSE $S64_ANSIBLE_SET_DEBUG \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_ansible_lib_run_doc() {
  bl64_dbg_app_show_function "$@"

  _s64_ansible_lib_cli_harden
  bl64_dbg_app_trace_start
  # shellcheck disable=SC2086
  "$S64_ANSIBLE_PATH_CLI_DOC" \
    $S64_ANSIBLE_SET_VERBOSE $S64_ANSIBLE_SET_DEBUG \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_ansible_lib_run_galaxy() {
  bl64_dbg_app_show_function "$@"

  _s64_ansible_lib_cli_harden
  bl64_dbg_app_trace_start
  # shellcheck disable=SC2086
  "$S64_ANSIBLE_PATH_CLI_GALAXY" \
    $S64_ANSIBLE_SET_VERBOSE $S64_ANSIBLE_SET_DEBUG \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_ansible_lib_run_inventory() {
  bl64_dbg_app_show_function "$@"

  _s64_ansible_lib_cli_harden
  s64_ansible_lib_cli_set

  bl64_dbg_app_trace_start
  # shellcheck disable=SC2086
  "$S64_ANSIBLE_PATH_CLI_INVENTORY" \
    $S64_ANSIBLE_SET_VERBOSE $S64_ANSIBLE_SET_DEBUG \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_ansible_lib_run_config() {
  bl64_dbg_app_show_function "$@"

  _s64_ansible_lib_cli_harden
  s64_ansible_lib_cli_set

  bl64_dbg_app_trace_start
  # shellcheck disable=SC2086
  "$S64_ANSIBLE_PATH_CLI_CONFIG" \
    $S64_ANSIBLE_SET_VERBOSE $S64_ANSIBLE_SET_DEBUG \
    "$@"
  bl64_dbg_app_trace_stop
}
