#
# Imports
#

# shellcheck disable=SC2154,SC2015
source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" ||
  { s64_core_lib_check_bl64 && exit 1; }

#
# Module parameters
#

# shellcheck disable=SC2034
{
  declare S64_CILIUM_PATH_CLI="${S64_CILIUM_PATH_CLI:-}"

  declare S64_CILIUM_SET_VERSION="${S64_CILIUM_SET_VERSION:-1.19.4}"
}

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_CILIUM_VERSION='1.0.0'
  declare S64_CILIUM_ABOUT_MODULE_MAIN='Cilium - eBPF-based Networking'
}

#
# Functions
#

function s64_cilium_lib_setup() {
  bl64_dbg_app_show_function
  s64_core_lib_module_show_about "$S64_CILIUM_ABOUT_MODULE_MAIN" &&
    s64_core_lib_command_require 'S64_CILIUM_PATH_CLI' 'cilium'
}

function s64_cilium_lib_run_cilium() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  "$S64_CILIUM_PATH_CLI" \
    "$@"
  bl64_dbg_app_trace_stop
}
