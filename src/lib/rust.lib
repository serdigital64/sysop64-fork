#
# Imports
#

# shellcheck disable=SC2154,SC2015
source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" ||
  { s64_core_lib_check_bl64 && exit 1; }

#
# Module parameters
#

# shellcheck disable=SC2034
{
  declare S64_RUST_PATH_CLI_CARGO="${S64_RUST_PATH_CLI_CARGO:-}"
}

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_RUST_VERSION='1.0.0'
  declare S64_RUST_ABOUT_MODULE_MAIN='Rust - Programming Language'
}

#
# Functions
#

function s64_rust_lib_setup() {
  bl64_dbg_app_show_function
  s64_core_lib_module_show_about "$S64_RUST_ABOUT_MODULE_MAIN" &&
    s64_core_lib_command_require 'S64_RUST_PATH_CLI_CARGO' 'cargo' "${HOME}/.cargo/bin"
}

function s64_rust_lib_run_cargo() {
  bl64_dbg_app_show_function "$@"
  local verbose_flag='--verbose'
  bl64_msg_app_detail_is_enabled || verbose_flag=' '
  bl64_dbg_app_trace_start
  # shellcheck disable=SC2086
  "$S64_RUST_PATH_CLI_CARGO" \
    $verbose_flag \
    "$@"
  bl64_dbg_app_trace_stop
}
