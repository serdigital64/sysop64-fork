#
# Imports
#

# shellcheck disable=SC2154,SC2015
source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" ||
  { s64_core_lib_check_bl64 && exit 1; }

#
# Module parameters
#

# shellcheck disable=SC2034
{
  # Journalctl / Filter by lines
  declare S64_SYSTEMD_SET_JOURNALCTL_LINES="${S64_SYSTEMD_SET_JOURNALCTL_LINES:-100}"
  # Journalctl / Filter by time
  declare S64_SYSTEMD_SET_JOURNALCTL_SINCE="${S64_SYSTEMD_SET_JOURNALCTL_SINCE:-}"
  # Journalctl / Output format
  declare S64_SYSTEMD_SET_JOURNALCTL_OUTPUT="${S64_SYSTEMD_SET_JOURNALCTL_OUTPUT:-short-iso}"
}

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_SYSTEMD_VERSION='1.0.0'
  declare S64_SYSTEMD_ABOUT_MODULE_MAIN='Linux System Manager'

  S64_SYSTEMD_PATH_CLI_HOSTNAMECTL='/usr/bin/hostnamectl'
  S64_SYSTEMD_PATH_CLI_JOURNALCTL='/usr/bin/journalctl'
  S64_SYSTEMD_PATH_CLI_RESOLVECTL='/usr/bin/resolvectl'
  S64_SYSTEMD_PATH_CLI_SYSTEMCTL='/usr/bin/systemctl'
  S64_SYSTEMD_PATH_CLI_SYSTEMD_ANALYZE='/usr/bin/systemd-analyze'

  S64_SYSTEMD_DB_RESOLVED='systemd/resolved.conf'
  S64_SYSTEMD_SERVICE_RESOLVED='systemd-resolved'
}

#
# External
#

# shellcheck disable=SC2034
{
  export SYSTEMD_PAGER
  export SYSTEMD_PAGERSECURE
}

#
# Functions
#

function s64_systemd_lib_setup() {
  bl64_dbg_app_show_function
  s64_core_lib_module_show_about "$S64_SYSTEMD_ABOUT_MODULE_MAIN"
  SYSTEMD_PAGER="$S64_CORE_SET_PAGER"
  SYSTEMD_PAGERSECURE='true'
  return 0
}

function s64_systemd_lib_setup_secondary() {
  bl64_dbg_app_show_function
  bl64_dbg_app_show_comments 'use this function instead of s64_systemd_lib_setup when not the primary module'
  S64_CORE_SET_MODULE_PRIMARY='NO' s64_systemd_lib_setup
}

function s64_systemd_lib_run_hostnamectl() {
  bl64_dbg_app_show_function "$@"
  bl64_check_command "$S64_SYSTEMD_PATH_CLI_HOSTNAMECTL" "$BL64_VAR_DEFAULT" 'S64_SYSTEMD_PATH_CLI_HOSTNAMECTL' ||
    return $?
  bl64_dbg_app_trace_start
  "$S64_SYSTEMD_PATH_CLI_HOSTNAMECTL" \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_systemd_lib_run_journalctl() {
  bl64_dbg_app_show_function "$@"
  bl64_check_command "$S64_SYSTEMD_PATH_CLI_JOURNALCTL" "$BL64_VAR_DEFAULT" 'S64_SYSTEMD_PATH_CLI_JOURNALCTL' ||
    return $?
  bl64_dbg_app_trace_start
  "$S64_SYSTEMD_PATH_CLI_JOURNALCTL" \
    --utc \
    --all \
    --quiet \
    --output="$S64_SYSTEMD_SET_JOURNALCTL_OUTPUT" \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_systemd_lib_run_journalctl_filter() {
  bl64_dbg_app_show_function "$@"
  s64_systemd_lib_run_journalctl \
    ${S64_SYSTEMD_SET_JOURNALCTL_SINCE:+--since="$S64_SYSTEMD_SET_JOURNALCTL_SINCE"} \
    --lines="$S64_SYSTEMD_SET_JOURNALCTL_LINES" "$@"
}

function s64_systemd_lib_run_resolvectl() {
  bl64_dbg_app_show_function "$@"
  bl64_check_command "$S64_SYSTEMD_PATH_CLI_RESOLVECTL" "$BL64_VAR_DEFAULT" 'S64_SYSTEMD_PATH_CLI_RESOLVECTL' ||
    return $?
  bl64_dbg_app_trace_start
  "$S64_SYSTEMD_PATH_CLI_RESOLVECTL" \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_systemd_lib_run_systemctl() {
  bl64_dbg_app_show_function "$@"
  bl64_check_command "$S64_SYSTEMD_PATH_CLI_SYSTEMCTL" "$BL64_VAR_DEFAULT" 'S64_SYSTEMD_PATH_CLI_SYSTEMCTL' ||
    return $?
  bl64_dbg_app_trace_start
  "$S64_SYSTEMD_PATH_CLI_SYSTEMCTL" \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_systemd_lib_run_systemd_analyze() {
  bl64_dbg_app_show_function "$@"
  bl64_check_command "$S64_SYSTEMD_PATH_CLI_SYSTEMD_ANALYZE" "$BL64_VAR_DEFAULT" 'S64_SYSTEMD_PATH_CLI_SYSTEMD_ANALYZE' ||
    return $?
  bl64_dbg_app_trace_start
  "$S64_SYSTEMD_PATH_CLI_SYSTEMD_ANALYZE" \
    "$@"
  bl64_dbg_app_trace_stop
}
