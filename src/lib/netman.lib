#
# Imports
#

# shellcheck disable=SC2154,SC2015
source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" ||
  { s64_core_lib_check_bl64 && exit 1; }

#
# Module parameters
#

# shellcheck disable=SC2034
{
  declare S64_NETMAN_SET_OUTPUT_MODE="${S64_NETMAN_SET_OUTPUT_MODE:-tabular}"
}

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_NETMAN_VERSION='1.0.0'
  declare S64_NETMAN_ABOUT_MODULE_MAIN='Linux Network Manager'

  # SystemD service name
  declare S64_NETMAN_SERVICE_NAME='NetworkManager'

  declare S64_NETMAN_PATH_CLI_NMCLI='/usr/bin/nmcli'
  declare S64_NETMAN_PATH_CLI_NETMAN='/usr/sbin/NetworkManager'
}

#
# Functions
#

function s64_netman_lib_setup() {
  bl64_dbg_app_show_function
  s64_core_lib_module_show_about "$S64_NETMAN_ABOUT_MODULE_MAIN" &&
    bl64_check_command "$S64_NETMAN_PATH_CLI_NMCLI" "$BL64_VAR_DEFAULT" 'S64_NETMAN_PATH_CLI_NMCLI' &&
    bl64_check_command "$S64_NETMAN_PATH_CLI_NETMAN" "$BL64_VAR_DEFAULT" 'S64_NETMAN_PATH_CLI_NETMAN'
}

function s64_netman_lib_run_nmcli() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  "$S64_NETMAN_PATH_CLI_NMCLI" \
    --mode "$S64_NETMAN_SET_OUTPUT_MODE" \
    --pretty \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_netman_lib_run_netman() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  "$S64_NETMAN_PATH_CLI_NETMAN" \
    "$@"
  bl64_dbg_app_trace_stop
}
