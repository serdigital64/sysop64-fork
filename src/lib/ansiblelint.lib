#
# Imports
#

# shellcheck disable=SC2154,SC2015
source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" ||
  { s64_core_lib_check_bl64 && exit 1; }

#
# Module parameters
#

# shellcheck disable=SC2034
{
  declare S64_ANSIBLELINT_PATH_CLI="${S64_ANSIBLELINT_PATH_CLI:-}"
  declare S64_ANSIBLELINT_PATH_CONFIG="${S64_ANSIBLELINT_PATH_CONFIG:-}"
  declare S64_ANSIBLELINT_PATH_PROJECT="${S64_ANSIBLELINT_PATH_PROJECT:-.}"

  declare S64_ANSIBLELINT_SET_OFFLINE="${S64_ANSIBLELINT_SET_OFFLINE:-YES}"
  declare S64_ANSIBLELINT_SET_FORMAT="${S64_ANSIBLELINT_SET_FORMAT:-brief}"
}

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_ANSIBLELINT_VERSION='1.0.0'
  declare S64_ANSIBLELINT_ABOUT_MODULE_MAIN='AnsibleLint - Ansible source code linter'
}

#
# Functions
#

function s64_ansiblelint_lib_setup() {
  bl64_dbg_app_show_function
  s64_core_lib_module_show_about "$S64_ANSIBLELINT_ABOUT_MODULE_MAIN" &&
    s64_core_lib_command_require 'S64_ANSIBLELINT_PATH_CLI' 'ansible-lint' &&
    s64_core_lib_module_show_setup \
      'S64_ANSIBLELINT_SET_OFFLINE'
}

function s64_ansiblelint_lib_run_ansiblelint() {
  bl64_dbg_app_show_function "$@"
  local debug_flag='-v'
  local offline='--offline'

  bl64_dbg_app_command_is_enabled || debug_flag='-q'
  bl64_lib_flag_is_enabled "$S64_ANSIBLELINT_SET_OFFLINE" || offline='--no-offline'
  s64_ansiblelint_lib_harden

  bl64_dbg_app_trace_start
  # shellcheck disable=SC2086
  "$S64_ANSIBLELINT_PATH_CLI" \
    $debug_flag \
    $offline \
    ${S64_ANSIBLELINT_PATH_CONFIG:+--config-file "$S64_ANSIBLELINT_PATH_CONFIG"} \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_ansiblelint_lib_harden() {
  bl64_dbg_app_show_function

  bl64_dbg_lib_trace_start
  unset ANSIBLE_LINT_CUSTOM_RULESDIR
  unset ANSIBLE_LINT_IGNORE_FILE
  unset ANSIBLE_LINT_WRITE_TMP
  unset ANSIBLE_LINT_SKIP_SCHEMA_UPDATE
  unset ANSIBLE_LINT_NODEPS
  bl64_dbg_app_trace_stop
}
