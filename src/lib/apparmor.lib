#
# Imports
#

# shellcheck disable=SC2154,SC2015
source "${S64_CORE_PATH_BL64}/bashlib64-module-bsh.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fmt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-xsv.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-txt.bash" &&
  source "${S64_CORE_PATH_BL64}/bashlib64-module-fs.bash" ||
  { s64_core_lib_check_bl64 && exit 1; }

#
# Globals
#

# shellcheck disable=SC2034
{
  declare S64_APPARMOR_VERSION='1.0.0'
  declare S64_APPARMOR_ABOUT_MODULE_MAIN='AppArmor - Mandatory Access Control System'

  declare S64_APPARMOR_PATH_CLI_AA_ENABLED='/usr/bin/aa-enabled'
  declare S64_APPARMOR_PATH_CLI_AA_LOGPROF='/usr/bin/aa-logprof'
  declare S64_APPARMOR_PATH_CLI_AA_STATUS='/usr/bin/aa-status'
}

#
# Functions
#

function s64_apparmor_lib_setup() {
  bl64_dbg_app_show_function
  s64_core_lib_module_show_about "$S64_APPARMOR_ABOUT_MODULE_MAIN" &&
    bl64_os_check_flavor \
      "$BL64_OS_FLAVOR_ARCH" \
      "$BL64_OS_FLAVOR_DEBIAN" &&
    bl64_check_command "$S64_APPARMOR_PATH_CLI_AA_ENABLED"
}

function s64_apparmor_lib_run_aa_enabled() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  "$S64_APPARMOR_PATH_CLI_AA_ENABLED" \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_apparmor_lib_run_aa_logprof() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  "$S64_APPARMOR_PATH_CLI_AA_LOGPROF" \
    "$@"
  bl64_dbg_app_trace_stop
}

function s64_apparmor_lib_run_aa_status() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_app_trace_start
  "$S64_APPARMOR_PATH_CLI_AA_STATUS" \
    "$@"
  bl64_dbg_app_trace_stop
}
